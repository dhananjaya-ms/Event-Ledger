<configuration scan="true" debug="false">

  <!-- use spring.application.name if set, fallback to literal service id -->
  <property name="APP_NAME" value="${spring.application.name:-gateway-service}" />

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
      <providers>
        <timestamp>
          <fieldName>timestamp</fieldName>
          <!-- ISO-8601 with milliseconds in UTC -->
          <timeZone>UTC</timeZone>
          <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
        </timestamp>
        <logLevel>
          <fieldName>level</fieldName>
        </logLevel>
        <loggerName>
          <fieldName>logger</fieldName>
        </loggerName>
        <threadName>
          <fieldName>thread</fieldName>
        </threadName>
        <!-- include common trace id keys placed into MDC by tracing libs (Micrometer/Brave/OpenTelemetry)
             add several keys to be robust across instrumentation implementations -->
        <mdc>
          <includeMdcKeyName>traceId</includeMdcKeyName>
          <includeMdcKeyName>trace_id</includeMdcKeyName>
          <includeMdcKeyName>X-B3-TraceId</includeMdcKeyName>
          <includeMdcKeyName>trace-id</includeMdcKeyName>
        </mdc>
        <message>
          <fieldName>message</fieldName>
        </message>
        <stackTrace>
          <fieldName>stacktrace</fieldName>
        </stackTrace>
        <globalCustomFields>{"service":"${APP_NAME}"}</globalCustomFields>
      </providers>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT" />
  </root>

</configuration>
