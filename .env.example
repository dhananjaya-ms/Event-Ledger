# Docker Compose Environment Configuration Template
# Copy this file to .env and modify values as needed

# Gateway Service Configuration
GATEWAY_SERVICE_PORT=8080
GATEWAY_CONTAINER_PORT=8081

# Account Service Configuration
ACCOUNT_SERVICE_CONTAINER_PORT=8080

# Docker Network Name
DOCKER_NETWORK_NAME=event-ledger-network

# Environment Profile (development, docker, production)
SPRING_PROFILES_ACTIVE=docker

# Database Configuration (if you want to override)
# SPRING_DATASOURCE_URL=jdbc:h2:mem:eventdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=

# Account Service URL
ACCOUNT_SERVICE_URL=http://account-service:8080

# OpenTelemetry Configuration (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# H2 Console Configuration
H2_CONSOLE_ENABLED=true

# Logging Level
LOG_LEVEL=INFO
# Possible values: TRACE, DEBUG, INFO, WARN, ERROR
